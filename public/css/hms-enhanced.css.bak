     border-color: var(--hms-border) !important;
 }
 
 body.theme-dark .select2-container--bootstrap .select2-results__option {
     color: var(--hms-text) !important;
 }
 
 body.theme-dark .select2-container--bootstrap .select2-results__option--highlighted[aria-selected] {
