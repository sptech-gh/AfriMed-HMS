 body.theme-light {
     color-scheme: light;
 }

 body.theme-dark {
     color-scheme: dark;
 }

 /* Dark mode hard overrides (last-wins) to eliminate any remaining white hover/striped backgrounds */
 body.theme-dark.skin-blue .table-striped > tbody > tr:nth-of-type(odd),
 body.theme-dark.skin-blue .table-striped > tbody > tr:nth-of-type(even) {
     background-color: transparent !important;
