 }
 
 body.theme-dark .dataTables_wrapper .dataTables_filter input::placeholder {
     color: var(--hms-input-placeholder) !important;
 }
 
 body.theme-dark .dataTables_wrapper .dataTables_paginate .paginate_button,
 body.theme-dark .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
     color: var(--hms-text) !important;
 }
 
 body.theme-dark .daterangepicker {
     background: var(--hms-elevated) !important;
     border-color: var(--hms-border) !important;
     color: var(--hms-text) !important;
     box-shadow: 0 10px 25px rgba(0,0,0,0.45);
 }
 
 body.theme-dark .daterangepicker .calendar-table {
     background: transparent !important;
     border-color: var(--hms-border) !important;
 }
 
 body.theme-dark .daterangepicker td.available:hover,
 body.theme-dark .daterangepicker th.available:hover {
     background: var(--hms-hover) !important;
     color: var(--hms-text) !important;
 }
 
 body.theme-dark .daterangepicker td.active,
 body.theme-dark .daterangepicker td.active:hover {
     background-color: rgba(60,141,188,0.85) !important;
     color: var(--hms-primary-contrast) !important;
 }
 
 body.theme-dark .daterangepicker .ranges li {
     background: transparent !important;
     color: var(--hms-text) !important;
 }
 
 body.theme-dark .daterangepicker .ranges li:hover {
     background: var(--hms-hover) !important;
 }
 
 body.theme-dark .icheckbox_square-blue,
 body.theme-dark .iradio_square-blue,
 body.theme-dark .icheckbox_minimal-blue,
 body.theme-dark .iradio_minimal-blue {
     background-color: var(--hms-input-bg) !important;
     border: 1px solid var(--hms-input-border) !important;
 }
 
 body.theme-dark .icheckbox_square-blue.checked,
 body.theme-dark .iradio_square-blue.checked,
 body.theme-dark .icheckbox_minimal-blue.checked,
 body.theme-dark .iradio_minimal-blue.checked {
     background-color: rgba(60,141,188,0.85) !important;
     border-color: rgba(60,141,188,0.95) !important;
 }
 
 body.theme-dark .bootstrap-timepicker-widget.dropdown-menu {
     background: var(--hms-elevated) !important;
     border-color: var(--hms-border) !important;
     color: var(--hms-text) !important;
 }
 
 body.theme-dark .bootstrap-timepicker-widget table td a {
     color: var(--hms-text) !important;
 }
 
 body.theme-dark .bootstrap-timepicker-widget table td a:hover {
     background: var(--hms-hover) !important;
 }
