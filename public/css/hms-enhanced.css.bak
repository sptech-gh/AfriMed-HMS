 }
 
 body.theme-dark .select2-container--bootstrap .select2-selection--single .select2-selection__rendered {
     color: var(--hms-input-text) !important;
 }
 
 body.theme-dark .select2-container--bootstrap .select2-selection__placeholder {
     color: var(--hms-input-placeholder) !important;
 }
 
 body.theme-dark .select2-container--bootstrap .select2-dropdown {
