    /**
     * Billing Permissions Management (Admin only)
     */
    public function permissions()
    {
        if (!$this->billingauth->is_super_admin()) {
            $this->session->set_flashdata('error', 'Only Super Admin can manage billing permissions.');
            redirect('app/ebilling');
        }
        
        $this->session->set_userdata(array(
            'tab' => 'ebilling',
            'module' => 'ebilling_permissions',
            'subtab' => '',
            'submodule' => ''
        ));
        
        $this->data['page_title'] = 'Billing Permissions';
        $this->data['roles'] = $this->billingauth->get_all_roles();
        
        // Get users with billing roles
        $this->db->select('ubr.*, u.username, u.firstname, u.lastname');
        $this->db->from('user_billing_roles ubr');
        $this->db->join('users u', 'u.user_id = ubr.user_id');
        $this->data['user_roles'] = $this->db->get()->result();
        
        // Get all users for assignment
        $this->db->select('user_id, username, firstname, lastname');
        $this->db->where('InActive', 0);
        $this->db->order_by('firstname', 'ASC');
        $this->data['users'] = $this->db->get('users')->result();
        
        $this->load->view('app/enterprise_billing/permissions', $this->data);
    }
    
    /**
     * Update Role Permissions (AJAX)
     */
    public function update_role_permissions()
    {
        header('Content-Type: application/json');
        
        if (!$this->billingauth->is_super_admin()) {
            echo json_encode(['success' => false, 'error' => 'Permission denied']);
            return;
        }
        
        $role_key = $this->input->post('role_key');
        $permissions = [
            'can_create_invoice' => $this->input->post('can_create_invoice') ? 1 : 0,
            'can_edit_invoice' => $this->input->post('can_edit_invoice') ? 1 : 0,
            'can_delete_invoice' => $this->input->post('can_delete_invoice') ? 1 : 0,
            'can_collect_payment' => $this->input->post('can_collect_payment') ? 1 : 0,
            'can_refund' => $this->input->post('can_refund') ? 1 : 0,
            'can_view_reports' => $this->input->post('can_view_reports') ? 1 : 0,
            'can_reconcile' => $this->input->post('can_reconcile') ? 1 : 0,
            'can_approve_discount' => $this->input->post('can_approve_discount') ? 1 : 0,
            'can_view_audit' => $this->input->post('can_view_audit') ? 1 : 0,
            'can_manage_settings' => $this->input->post('can_manage_settings') ? 1 : 0
        ];
        
        $this->billingauth->update_role_permissions($role_key, $permissions);
        
        echo json_encode(['success' => true, 'message' => 'Permissions updated']);
    }
    
    /**
     * Assign Billing Role to User (AJAX)
     */
    public function assign_billing_role()
    {
        header('Content-Type: application/json');
        
        if (!$this->billingauth->is_super_admin()) {
            echo json_encode(['success' => false, 'error' => 'Permission denied']);
            return;
        }
        
        $user_id = $this->input->post('user_id');
        $role_key = $this->input->post('role_key');
        
        $this->billingauth->assign_role($user_id, $role_key);
        
        echo json_encode(['success' => true, 'message' => 'Role assigned']);
    }
}
