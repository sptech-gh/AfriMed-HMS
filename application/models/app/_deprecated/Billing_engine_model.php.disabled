<?php
defined('BASEPATH') OR exit('No direct script access allowed');

/**
 * Billing Engine Model - SINGLE SOURCE OF TRUTH
 * All billing events from all departments MUST flow through this engine.
 * 
 * @author HMS Enterprise Architect
 * @version 2.0
 */
class Billing_engine_model extends CI_Model
{
    public function __construct()
    {
        parent::__construct();
        $this->load->model('app/Enterprise_billing_model', 'eb_model');
        $this->eb_model->ensure_schema();
    }
    
    /**
     * Main event handler - Routes billing events
     */
    public function handle_event($event_type, $event_data)
    {
        $user_id = $this->session->userdata('user_id') ?? 'SYSTEM';
        $start_time = microtime(true);
        
        try {
            $this->validate_event_data($event_data);
            $result = $this->route_event($event_type, $event_data, $user_id);
            $this->log_event($event_type, $event_data, $result, $start_time, $user_id);
            return $result;
        } catch (Exception $e) {
            $this->log_event($event_type, $event_data, ['error' => $e->getMessage()], $start_time, $user_id, 'FAILED');
            return ['success' => false, 'error' => $e->getMessage()];
        }
    }
    
    private function route_event($event_type, $data, $user_id)
    {
        switch ($event_type) {
            case 'REGISTRATION_CREATED': return $this->handle_registration($data, $user_id);
            case 'CONSULTATION_STARTED': return $this->handle_consultation($data, $user_id);
            case 'LAB_ORDERED': return $this->handle_lab_order($data, $user_id);
            case 'PRESCRIPTION_CREATED': return $this->handle_prescription($data, $user_id);
            case 'RADIOLOGY_ORDERED': return $this->handle_radiology($data, $user_id);
            case 'SONOGRAPHY_ORDERED': return $this->handle_sonography($data, $user_id);
            case 'PROCEDURE_ORDERED': return $this->handle_procedure($data, $user_id);
            case 'ADMISSION_CREATED': return $this->handle_admission($data, $user_id);
            case 'ROOM_ASSIGNED': return $this->handle_room($data, $user_id);
            case 'SURGERY_SCHEDULED': return $this->handle_surgery($data, $user_id);
            case 'CONSUMABLE_USED': return $this->handle_consumable($data, $user_id);
            case 'DISPENSE_COMPLETED': return $this->handle_dispense_reconciliation($data, $user_id);
            case 'SERVICE_WAIVED': return $this->handle_waiver($data, $user_id);
            case 'SERVICE_DEFERRED': return $this->handle_deferral($data, $user_id);
            case 'DISCHARGE_INITIATED': return $this->lock_encounter($data, $user_id);
            default: throw new Exception("Unknown event: {$event_type}");
        }
    }
    
    private function validate_event_data($data)
    {
        if (empty($data['visit_id']) || empty($data['patient_no'])) {
            throw new Exception("Missing visit_id or patient_no");
        }
        if ($this->is_encounter_locked($data['visit_id'])) {
            throw new Exception("Encounter locked - cannot add charges");
        }
    }
    
    /* ================================================================== */
    /*  EVENT HANDLERS                                                     */
    /* ================================================================== */
    
    private function handle_registration($data, $user_id)
    {
        if ($this->charge_exists('REGISTRATION', $data['visit_id'])) {
            return ['success' => true, 'skipped' => true];
        }
        $fee = $this->get_fee('registration', $data['patient_no']);
        if ($fee <= 0) return ['success' => true, 'skipped' => true];
        
        return $this->create_transaction([
            'visit_id' => $data['visit_id'],
            'patient_no' => $data['patient_no'],
            'charge_type' => 'REGISTRATION',
            'charge_code' => 'REG-001',
            'charge_name' => 'Registration Fee',
            'department' => 'FRONT_DESK',
            'quantity' => 1,
            'unit_price' => $fee,
            'source_module' => 'REGISTRATION',
            'source_ref_id' => $data['visit_id'],
            'source_ref_table' => 'patient_details_iop',
            'event' => 'REGISTRATION_CREATED',
            'user_id' => $user_id,
            'create_gate' => false
        ]);
    }
    
    private function handle_consultation($data, $user_id)
    {
        if ($this->charge_exists('CONSULTATION', $data['visit_id'])) {
            return ['success' => true, 'skipped' => true];
        }
        $fee = $this->get_fee('consultation', $data['patient_no']);
        if ($fee <= 0) return ['success' => true, 'skipped' => true];
        
        return $this->create_transaction([
            'visit_id' => $data['visit_id'],
            'patient_no' => $data['patient_no'],
            'charge_type' => 'CONSULTATION',
            'charge_code' => 'CONSULT-001',
            'charge_name' => 'Consultation Fee',
            'department' => 'OPD',
            'quantity' => 1,
            'unit_price' => $fee,
            'source_module' => 'OPD',
            'source_ref_id' => $data['visit_id'],
            'source_ref_table' => 'patient_details_iop',
            'event' => 'CONSULTATION_STARTED',
            'user_id' => $user_id,
            'create_gate' => true
        ]);
    }
    
    private function handle_lab_order($data, $user_id)
    {
        if (empty($data['tests'])) throw new Exception("No tests provided");
        $results = [];
        foreach ($data['tests'] as $test) {
            $ref = $test['order_id'] ?? $test['lab_id'] ?? $data['visit_id'].'_'.$test['test_id'];
            if ($this->charge_exists_by_source('LABORATORY', $ref)) {
                $results[] = ['skipped' => true, 'test_id' => $test['test_id']];
                continue;
            }
            $price = $this->get_service_price('lab', $test['test_id'], $data['patient_no']);
            $results[] = $this->create_transaction([
                'visit_id' => $data['visit_id'],
                'patient_no' => $data['patient_no'],
                'charge_type' => 'LAB',
                'charge_code' => $test['test_code'] ?? 'LAB-'.$test['test_id'],
                'charge_name' => $test['test_name'],
                'department' => 'LABORATORY',
                'quantity' => 1,
                'unit_price' => $price,
                'source_module' => 'LABORATORY',
                'source_ref_id' => $ref,
                'source_ref_table' => 'io_lab',
                'event' => 'LAB_ORDERED',
                'user_id' => $user_id,
                'create_gate' => true,
                'nhis_code' => $test['nhis_code'] ?? null
            ]);
        }
        return ['success' => true, 'results' => $results];
    }
    
    private function handle_prescription($data, $user_id)
    {
        if (empty($data['medications'])) throw new Exception("No medications provided");
        $results = [];
        foreach ($data['medications'] as $med) {
            $ref = $med['prescription_id'] ?? $med['medication_id'] ?? $data['visit_id'].'_'.$med['drug_id'];
            if ($this->charge_exists_by_source('PHARMACY', $ref)) {
                $results[] = ['skipped' => true, 'drug_id' => $med['drug_id']];
                continue;
            }
            $price = $this->get_service_price('pharmacy', $med['drug_id'], $data['patient_no']);
            $results[] = $this->create_transaction([
                'visit_id' => $data['visit_id'],
                'patient_no' => $data['patient_no'],
                'charge_type' => 'PHARMACY',
                'charge_code' => $med['drug_code'] ?? 'DRUG-'.$med['drug_id'],
                'charge_name' => $med['drug_name'],
                'department' => 'PHARMACY',
                'quantity' => $med['quantity'] ?? 1,
                'unit_price' => $price,
                'source_module' => 'PHARMACY',
                'source_ref_id' => $ref,
                'source_ref_table' => 'iop_medication',
                'event' => 'PRESCRIPTION_CREATED',
                'user_id' => $user_id,
                'create_gate' => true
            ]);
        }
        return ['success' => true, 'results' => $results];
    }
    
