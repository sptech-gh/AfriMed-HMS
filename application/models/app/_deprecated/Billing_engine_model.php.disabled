        return $this->create_transaction([
            'visit_id' => $data['visit_id'],
            'patient_no' => $data['patient_no'],
            'encounter_type' => 'IPD',
            'charge_type' => 'ADMISSION',
            'charge_code' => 'ADM-001',
            'charge_name' => 'Admission Fee',
            'department' => 'IPD',
            'quantity' => 1,
            'unit_price' => $price,
            'source_module' => 'IPD',
            'source_ref_id' => $ref,
            'source_ref_table' => 'ipd_admissions',
            'event' => 'ADMISSION_CREATED',
            'user_id' => $user_id,
            'create_gate' => true
        ]);
    }
    
