            'unit_price' => $price,
            'source_module' => 'RADIOLOGY',
            'source_ref_id' => $ref,
            'source_ref_table' => 'io_radiology',
            'event' => 'RADIOLOGY_ORDERED',
            'user_id' => $user_id,
            'create_gate' => true
        ]);
    }
    
