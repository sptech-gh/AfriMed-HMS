            'encounter_type' => 'IPD',
            'charge_type' => 'ROOM',
            'charge_code' => 'ROOM-'.$data['room_id'],
            'charge_name' => $data['room_name'] ?? 'Room Charge',
            'department' => 'IPD',
            'quantity' => 1,
            'unit_price' => $price,
            'source_module' => 'IPD',
            'source_ref_id' => $ref,
            'source_ref_table' => 'ipd_room_assignments',
            'event' => 'ROOM_ASSIGNED',
